# Docker Hub image settings (publish your app image before deployment)
DOCKERHUB_USER=your-dockerhub-user
APP_IMAGE=docker.io/your-dockerhub-user/mockup-api-server:latest

# Host ports
APP_PORT=8080
DB_ADMIN_PORT=8082

# Database connection
DB_HOST=db
DB_PORT=3306
DB_NAME=mockupdb
DB_USER=mockuser
DB_PASSWORD=mockpass
DB_ROOT_PASSWORD=rootpass

# Database persistence on host
DB_DATA_PATH=./.docker/mysql-data

# Optional app settings
JWT_SECRET=change_me_in_production
JWT_EXPIRATION=86400000
